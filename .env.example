# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# AI/ML Services
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Blockchain/LUKSO Configuration
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
LUKSO_RPC_URL=https://42.rpc.thirdweb.com
LUKSO_TESTNET_RPC_URL=https://4201.rpc.thirdweb.com

# Security (IMPORTANT: Generate strong secrets!)
# Use: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
SESSION_SECRET=your_session_secret_minimum_32_characters_long

# Application Configuration
NODE_ENV=production
PORT=5000
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# CORS Configuration
CORS_ORIGINS=https://your-domain.vercel.app

# Storage (Optional)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token
IPFS_GATEWAY_URL=https://api.universalprofile.cloud/ipfs

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15
RATE_LIMIT_GENERATIONS=10
RATE_LIMIT_UPLOADS=50

# AI Service Rate Limiting
GEMINI_RATE_LIMIT_REQUESTS=50
GEMINI_RATE_LIMIT_WINDOW=60

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
ENABLE_IPFS_STORAGE=false
ENABLE_LUKSO_PROFILES=true
ENABLE_PAYMENTS=false
ENABLE_ANALYTICS=false

# Supabase (Optional - for payments)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# External APIs (Optional)
LYX_PRICE_API_URL=
COINGECKO_API_KEY=

# Email (Future - Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
