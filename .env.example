# =============================================================================
# X402 Payment System - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Required: X402 Payment System Configuration
# -----------------------------------------------------------------------------
# Thirdweb Secret Key - Required for X402 payment processing
# Get from: https://thirdweb.com/dashboard
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key_here

# Thirdweb Client ID - Required for frontend wallet operations
# Get from: https://thirdweb.com/dashboard
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here

# Server Wallet Address - Required for receiving payments
# This is the wallet address that will receive all X402 payments
# Format: 0x followed by 40 hex characters
SERVER_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Required: Wallet Authentication (Privy)
# -----------------------------------------------------------------------------
# Privy App ID - Required for wallet connection
# Get from: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=cm_your_privy_app_id_here

# Privy Client ID - Required for wallet connection
# Get from: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id_here

# -----------------------------------------------------------------------------
# Required: Database (Supabase)
# -----------------------------------------------------------------------------
# Supabase Project URL - Required for data persistence
# Get from: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key - Required for server-side operations
# Get from: https://supabase.com/dashboard → Settings → API
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase Anon Key - Required for client-side operations
# Get from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# Optional: MongoDB (Alternative Database)
# -----------------------------------------------------------------------------
# MongoDB Connection URI - Optional, only if using MongoDB instead of Supabase
# MONGODB_URI=mongodb://localhost:27017/x402-payments

# MongoDB Database Name - Optional, defaults to 'x402-payments'
# MONGODB_DB_NAME=x402-payments

# -----------------------------------------------------------------------------
# Required: AI Image Generation (Google Gemini - Nano Banana)
# -----------------------------------------------------------------------------
# Google Gemini API Key - Required for image generation
# Get from: https://aistudio.google.com/apikey
# Models: gemini-2.5-flash-image (fast), gemini-3-pro-image-preview (premium)
# Pricing: ~$0.039 per 1024x1024 image
# Rate Limits (Free): 2 images/min, 250 requests/day
# Rate Limits (Paid): 10 images/min, unlimited daily
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Optional: Encryption Keys
# -----------------------------------------------------------------------------
# Prompt Encryption Key - Optional, for encrypting prompt content
# PROMPT_ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Field Encryption Key (Base64) - Optional, for field-level encryption
# FIELD_ENCRYPTION_KEY_B64=your_base64_encryption_key_here

# Content Access Token Secret (required) - signs time-limited prompt access tokens
# Must be at least 32 characters. Generate with: openssl rand -hex 32
CONTENT_ACCESS_TOKEN_SECRET=your_secret_here_min_32_chars

# -----------------------------------------------------------------------------
# Optional: Application Configuration
# -----------------------------------------------------------------------------
# Application Base URL - Optional, defaults to request URL
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name — used in UI labels, sign-in messages, and localStorage key prefix
# Change this to rebrand without touching source code
NEXT_PUBLIC_APP_NAME=Enki

# Platform fee applied to all purchases (default: 0.05 = 5%)
# PLATFORM_FEE_PERCENT=0.05

# Terms of Service and Privacy Policy URLs — shown in the wallet connect modal
# Leave empty to hide the links
# NEXT_PUBLIC_TERMS_URL=https://yourapp.com/terms
# NEXT_PUBLIC_PRIVACY_URL=https://yourapp.com/privacy

# -----------------------------------------------------------------------------
# Turnkey Integration (2FA + Embedded Wallets)
# -----------------------------------------------------------------------------
# Get from: https://app.turnkey.com → Settings → API Keys
TURNKEY_API_PUBLIC_KEY=your_turnkey_api_public_key
TURNKEY_API_PRIVATE_KEY=your_turnkey_api_private_key

# Get from: https://app.turnkey.com → Organizations
TURNKEY_ORGANIZATION_ID=your_turnkey_org_id
NEXT_PUBLIC_TURNKEY_ORGANIZATION_ID=your_turnkey_org_id

# -----------------------------------------------------------------------------
# Solana x402 Payment Configuration
# -----------------------------------------------------------------------------
# Solana platform wallet address (base58) - receives USDC payments on Solana
SOLANA_PLATFORM_WALLET=your_solana_platform_wallet_pubkey_here
# Public mirror of SOLANA_PLATFORM_WALLET used by the browser to reject tampered 402 payment recipients.
NEXT_PUBLIC_SOLANA_PLATFORM_WALLET=your_solana_platform_wallet_pubkey_here

# Solana program ID (deployed to devnet/mainnet)
NEXT_PUBLIC_PROGRAM_ID=GdKHLpEPWC6xLjDjgKDJ1FPkZmmKnxGcCH1NebC8S6XD

# -----------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# -----------------------------------------------------------------------------
# Analytics Endpoint - Optional, for payment analytics tracking
# ANALYTICS_ENDPOINT=https://your-analytics-endpoint.com/api/payments
