# AIgency Production Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://username:password@localhost:5432/aiagency
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ========================================
# AI/ML SERVICES
# ========================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_RATE_LIMIT_REQUESTS=50
GEMINI_RATE_LIMIT_WINDOW=60

# ========================================
# BLOCKCHAIN/LUKSO
# ========================================
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
TREASURY_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e
LUKSO_RPC_URL=https://42.rpc.thirdweb.com
LUKSO_TESTNET_RPC_URL=https://4201.rpc.thirdweb.com

# ========================================
# STORAGE
# ========================================
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
IPFS_GATEWAY_URL=https://api.universalprofile.cloud/ipfs

# ========================================
# EXTERNAL APIs
# ========================================
LYX_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=lukso-token&vs_currencies=usd
COINGECKO_API_KEY=your-coingecko-api-key

# ========================================
# APPLICATION
# ========================================
NODE_ENV=production
PORT=5000
NEXT_PUBLIC_APP_URL=https://your-domain.com
JWT_SECRET=your-256-bit-jwt-secret-key
SESSION_SECRET=your-session-secret-key
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ========================================
# SECURITY & RATE LIMITING
# ========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15
RATE_LIMIT_GENERATIONS=10
RATE_LIMIT_UPLOADS=50

# ========================================
# MONITORING
# ========================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=info

# ========================================
# EMAIL (Optional)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_IPFS_STORAGE=false
ENABLE_LUKSO_PROFILES=true
ENABLE_PAYMENTS=false
ENABLE_ANALYTICS=false
